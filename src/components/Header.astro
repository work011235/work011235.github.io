---
// src/components/Header.astro
const path = Astro.url.pathname;

const links = [
  { href: '/',         label: 'writing'  },
  { href: '/tags',     label: 'tags'     },
  { href: '/projects', label: 'projects' },
  { href: '/about',    label: 'about'    },
];

function active(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="site-header">
  <div class="header-row">
    <div>
      <div>CloudNative</div>
      <a href="/" style="text-decoration:none">
        <span class="site-name">work011235.github.io<span class="cursor"></span></span>
      </a>
      <div class="site-tag">Electronic lab notebook with roadmap, lessons learned, and splotches and spills along the way.</div>
    </div>
    <button class="theme-btn" id="themeToggle" aria-label="Toggle theme">[ dark ]</button>
  </div>

  <div class="sub-bar">
    <span class="sub-label">follow</span>

    <a href="https://github.com/davidsteen218" target="_blank" rel="noopener noreferrer" class="sub-btn" aria-label="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      GitHub
    </a>

    <a href="https://linkedin.com/in/davidsteen218" target="_blank" rel="noopener noreferrer" class="sub-btn" aria-label="LinkedIn">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>

    <a href="mailto:davidsteen218@gmail.com" class="sub-btn" aria-label="Email">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
      </svg>
      Email
    </a>

    <a href="/feed.xml" class="sub-btn" aria-label="RSS Feed">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
      </svg>
      RSS
    </a>
  </div>
</header>

<nav class="site-nav">
  {links.map(l => (
    <a href={l.href} class="nav-link" aria-current={active(l.href) ? 'page' : undefined}>
      {l.label}
    </a>
  ))}
</nav>
