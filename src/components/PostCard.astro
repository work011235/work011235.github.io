---
// src/components/PostCard.astro
interface Props {
  title:       string;
  date:        Date;
  description: string;
  tags:        string[];
  slug:        string;
}
const { title, date, description, tags, slug } = Astro.props;
const fmt = date.toLocaleDateString('en-CA');
---
<li class="post-item">
  <span class="post-date">{fmt}</span>
  <div class="post-meta">
    <a href={`/blog/${slug}`} class="post-title">{title}</a>
    <span class="post-excerpt">{description}</span>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map(t => <a href={`/tags/${t}`} class="tag">{t}</a>)}
      </div>
    )}
  </div>
</li>
