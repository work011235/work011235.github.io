---
// src/pages/projects.astro
// Edit this array to add/remove projects.
import Base   from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    name: 'Recipe Box',
    desc: 'Leveraging Markdown readability across platforms and across versions, I have completed an alpha test hosting recipes typed up during high school.  Beta launch will update to host recipes use daily.  Future improvements will include layering in an ingredient registry, FDA Daily Reference values, an a nutrition calculator template to allow greater understanding of target nutrition. Follow at #recipebox.',
    tags: ['markdown', 'recipebox'],
    href: 'https://steenrecipebox.github.io/',
    year: '2026',
  },
  {
    name: 'Cycle Menu Planning',
    desc: 'In our journey through infertility, diet has been an element we have been watching.  Once daily used recipes have been captured, include layering in an ingredient registry, FDA Daily Reference values, and a nutrition calculator template to allow greater understanding of target nutrition.  Follow at #cycleplanning.',
    tags: ['markdown', 'cycleplanning'],
    href: 'https://steenrecipebox.github.io/',
    year: '2026',
  },
  {
    name: 'Draft Grocery Shopping List',
    desc: 'Low hanging fruit with strutured recipe data will be creating a grocery shopping list.  Follow at #grocerylist.',
    tags: ['markdown', 'grocerylist'],
    href: 'https://steenrecipebox.github.io/',
    year: '2026',
  },
];
---
<Base title="Projects — work011235.github.io">
  <Header />
  <main>
    <p class="section-label">// projects</p>
    <ul class="post-list">
      {projects.map(p => (
        <li class="post-item">
          <span class="post-date">{p.year}</span>
          <div class="post-meta">
            <a href={p.href} target="_blank" rel="noopener noreferrer" class="proj-link">{p.name} ↗</a>
            <span class="post-excerpt">{p.desc}</span>
            <div class="tags">{p.tags.map(t => <span class="tag">{t}</span>)}</div>
          </div>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Base>
